TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token

# Comma-separated Telegram user IDs. Leave empty only if everyone who can message the bot may use it.
ALLOWED_TELEGRAM_IDS=123456789

# Public HTTPS callback URL registered in Google Cloud.
OAUTH_REDIRECT_URI=https://api.your-domain.example/google/callback
OAUTH_HOST=127.0.0.1
OAUTH_PORT=8000

GOOGLE_CLIENT_SECRETS_FILE=credentials/client_secret.json
DATABASE_PATH=tokens/drivebot.sqlite3
DOWNLOAD_DIR=downloads
TOKEN_DIR=tokens
LOG_LEVEL=INFO
